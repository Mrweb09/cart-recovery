# ============================================================
# CART RECOVERY — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# ============================================================

# ---- SUPABASE (get from supabase.com → project → settings → API) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- ANTHROPIC (get from console.anthropic.com → API keys) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- RESEND (get from resend.com → API keys) ----
# Used as fallback if client doesn't have their own Resend key
RESEND_API_KEY=re_...
RESEND_FROM_DOMAIN=yourdomain.com

# ---- APP ----
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Secret for protecting the cron job endpoint — generate a random string
CRON_SECRET=generate-a-random-32-char-string-here

# ---- DASHBOARD AUTH (simple password protection) ----
DASHBOARD_PASSWORD=change-this-to-something-secure
